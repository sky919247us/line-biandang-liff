# 應用程式設定
APP_NAME=LINE便當訂購系統
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production

# 資料庫設定
DATABASE_URL=sqlite:///./biandang.db

# Redis 設定
REDIS_URL=redis://localhost:6379

# LINE 設定
LINE_CHANNEL_ID=your-channel-id
LINE_CHANNEL_SECRET=your-channel-secret
LINE_CHANNEL_ACCESS_TOKEN=your-messaging-api-token
LINE_LIFF_ID=your-liff-id

# Google Maps 設定（可選）
# 啟用後可精確計算配送距離，未啟用則使用手動審核模式
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_ENABLED=false

# 店家設定
STORE_LATITUDE=24.1378
STORE_LONGITUDE=120.6828
STORE_ADDRESS=台中市中區興中街20號

# 配送設定
MAX_DELIVERY_DISTANCE_KM=5
MIN_ORDER_AMOUNT=150

# 營業時間設定
BUSINESS_HOURS_START=10:00
BUSINESS_HOURS_END=16:30
DAILY_ORDER_LIMIT=100
